# ============================================================
# .env.example — plantilla de configuración local
# Copiá este archivo como .env y completá con tus valores.
# NUNCA pongas credenciales reales en .env.example.
# NUNCA subas .env a GitHub (.gitignore ya lo excluye).
# ============================================================

# Ambiente de ejecución.
# "local"      → usa SQLite, no toca producción.
# "production" → solo en Render (se configura allá, no aquí).
APP_ENV=local

# Base de datos.
# LOCAL: dejá DATABASE_URL comentado → la app usa SQLite automáticamente.
# STAGING (opcional): apuntá a una base PostgreSQL de prueba, NUNCA a la productiva.
# PRODUCCIÓN: Render inyecta DATABASE_URL como variable real de entorno — no va aquí.
#
# DATABASE_URL=postgresql://usuario:password@host-staging/db_staging

# ===== Configuración correo saliente =====
MAIL_FROM_NAME=Web Comparativas – Suizo Argentina
MAIL_FROM_EMAIL=no-reply@suizo.com.ar

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=tu.usuario@suizoargentina.com
SMTP_PASS=tu_password_smtp
SMTP_TLS=1

# URL pública (local)
APP_PUBLIC_URL=http://127.0.0.1:8000

# Administradores (separados por coma)
ADMIN_EMAILS=admin@suizoargentina.com
