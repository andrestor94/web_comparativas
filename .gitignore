# =============================================================
# .gitignore — SIEM / web_comparativas_v2
# =============================================================

# --- Python bytecode & caches ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# --- Virtual environments ---
venv_webcomparativas/
venv/
.venv/
env/

# --- Bases de datos locales ---
# OJO: usar *.db* (con wildcard final) para cubrir tambien los sidecar/copias
# de SQLite: app.db-journal, app.db-wal, app.db-shm, app.db.backup, etc.
# Si esto vuelve a quedar en "*.db" pelado, esos archivos pesados se cuelan al
# arbol y, con --reload, tildan la maquina.
*.db*
*.sqlite3
*.sqlite

# --- Backups locales de DB (deben vivir FUERA del arbol del proyecto) ---
_backups_db_local/

# --- Variables de entorno y secretos ---
.env
.env.*
*.pem
*.key

# --- Archivos de deployment generados ---
*.egg-info/
dist/
build/
.eggs/

# --- Logs y outputs temporales ---
*.log
*.out
debug_*.txt
debug_*.json

# --- Archivos temporales de descarga ---
web_comparativas/static/temp_dl/

# --- Uploads de usuarios (datos de runtime) ---
data/uploads/
web_comparativas/static/uploads/
web_comparativas/data/uploads/

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Claude Code / herramientas locales ---
.claude/
scratch/
selenium-profile/

# --- Archivos de construcción de análisis / pruebas ---
*.csv
*.json
sim_result*
test_out*
golden_master*
commit_diff*

# --- Indicadores Comerciales: datos pesados del ERP (no son codigo) ---
Indicadores Comerciales/
# Backups locales
*.bak
*.db.bak*
